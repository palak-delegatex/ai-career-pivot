{
  "manifest_version": 3,
  "name": "AICareerPivot — Job Saver & ATS Score",
  "version": "1.0.0",
  "description": "Save jobs from LinkedIn, Indeed, Glassdoor & more. Get instant ATS match scores and autofill applications.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "identity",
    "alarms"
  ],
  "host_permissions": [
    "https://*.linkedin.com/*",
    "https://*.indeed.com/*",
    "https://*.glassdoor.com/*",
    "https://*.ziprecruiter.com/*",
    "https://*.greenhouse.io/*",
    "https://*.lever.co/*",
    "https://*.myworkdayjobs.com/*",
    "https://*.ashbyhq.com/*",
    "https://ai-career-pivot.vercel.app/*",
    "https://*.supabase.co/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.linkedin.com/jobs/*",
        "https://*.linkedin.com/job/*"
      ],
      "js": ["content/detector.js", "content/injector.js"],
      "css": ["content/injector.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*.indeed.com/viewjob*",
        "https://*.indeed.com/jobs*"
      ],
      "js": ["content/detector.js", "content/injector.js"],
      "css": ["content/injector.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*.glassdoor.com/job-listing/*",
        "https://*.glassdoor.com/Job/*"
      ],
      "js": ["content/detector.js", "content/injector.js"],
      "css": ["content/injector.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*.ziprecruiter.com/jobs/*"
      ],
      "js": ["content/detector.js", "content/injector.js"],
      "css": ["content/injector.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*.greenhouse.io/applications/*",
        "https://boards.greenhouse.io/*",
        "https://*.lever.co/applications/*",
        "https://*.myworkdayjobs.com/*",
        "https://*.ashbyhq.com/*/application/*"
      ],
      "js": ["content/autofill.js", "content/ai-generate.js"],
      "css": ["content/injector.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*.linkedin.com/jobs/application/*",
        "https://*.linkedin.com/talent/applications/*",
        "https://*.indeed.com/applystart*",
        "https://*.indeed.com/apply/*",
        "https://*.glassdoor.com/apply/*",
        "https://*.ziprecruiter.com/apply/*"
      ],
      "js": ["content/autofill.js", "content/ai-generate.js"],
      "css": ["content/injector.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "options_page": "options/options.html",
  "commands": {
    "save-job": {
      "suggested_key": { "default": "Ctrl+Shift+S", "mac": "MacCtrl+Shift+S" },
      "description": "Save current job & score"
    },
    "autofill": {
      "suggested_key": { "default": "Ctrl+Shift+A", "mac": "MacCtrl+Shift+A" },
      "description": "Autofill application form"
    },
    "open-dashboard": {
      "suggested_key": { "default": "Ctrl+Shift+D", "mac": "MacCtrl+Shift+D" },
      "description": "Open AICareerPivot dashboard"
    }
  }
}
